@model IEnumerable<examen.Models.SalidaInventario>

@{
    ViewData["Title"] = "SalidaInventario";
}

<h1>Salida de Inventario</h1>
<div style="margin:30px;" class="d-grid gap-2">
    <a asp-action="CrearSalida" class="btn btn-lg btn-primary" type="button">Añadir Salida</a>
</div>
<table class="table table-hover">
    <thead>
        <tr>
            <th scope="col">Id</th>
            <th scope="col">Producto</th>
            <th scope="col">Cantidad</th>
            <th scope="col">Fecha</th>
            <th scope="col">Motivo</th>
            <th scope="col" style="width:220px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var salida in Model)
        {
            <tr class="table-active">
                <th scope="row">@salida.Id</th>
                <td>@salida.Producto?.Nombre</td>
                <td>@salida.Cantidad</td>
                <td>@salida.Fecha</td>
                <td>@salida.Motivo</td>
                <td>
                    <a asp-action="EditarSalida" asp-route-id="@salida.Id" type="button" class="btn btn-outline-success">Editar</a>
                    <a asp-action="DetalleSalida" asp-route-id="@salida.Id" type="button" class="btn btn-outline-success">Detalles</a>
                </td>


            </tr>
        }
        
    </tbody>
</table>
